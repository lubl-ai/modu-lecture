# app/backend/.env — FastAPI 전용
# 이 파일을 복사해서 .env 만들고 실제 값 채우기: cp .env.example .env

# Project URL — Settings > General > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Secret key — Settings > API Keys > Secret keys > 눈 아이콘 클릭해서 복사
# 새 형식: sb_secret_... / 구 형식: eyJhbGci...
# 절대 공개 금지 — RLS 우회 권한. Git 커밋 금지.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key-here
