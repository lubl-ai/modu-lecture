# app/frontend/.env.local — Next.js 전용
# 이 파일을 복사해서 .env.local 만들고 실제 값 채우기: cp .env.local.example .env.local

# Supabase — Settings > General > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable key — Settings > API Keys > Publishable key (sb_publishable_...)
# RLS 설정 시 브라우저 노출 가능
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here

# FastAPI Backend URL — 로컬 개발 시 localhost, 배포 후 Railway URL로 교체
NEXT_PUBLIC_API_URL=http://localhost:8000
